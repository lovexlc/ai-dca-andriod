<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_marginTop="12dp"
  android:background="@drawable/token_surface"
  android:orientation="vertical"
  android:padding="14dp">

  <TextView
    android:id="@+id/messageTitleTextView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:textColor="@color/ink"
    android:textSize="15sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/messageMetaTextView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:textColor="@color/slate_500"
    android:textSize="12sp" />

  <TextView
    android:id="@+id/messageBodyTextView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:lineSpacingExtra="3dp"
    android:textColor="@color/slate_700"
    android:textSize="14sp" />

  <TextView
    android:id="@+id/messageDetailTextView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:lineSpacingExtra="3dp"
    android:textColor="@color/slate_600"
    android:textSize="13sp" />

  <Button
    android:id="@+id/openMessageDetailButton"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:minHeight="0dp"
    android:minWidth="0dp"
    android:paddingLeft="12dp"
    android:paddingTop="8dp"
    android:paddingRight="12dp"
    android:paddingBottom="8dp"
    android:text="@string/message_action_open_detail"
    android:textAllCaps="false"
    android:textSize="12sp" />
</LinearLayout>
