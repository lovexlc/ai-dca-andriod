<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/rootScrollView"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/surface_page"
  android:fillViewport="true">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
      android:id="@+id/titleTextView"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:text="@string/app_name"
      android:textColor="@color/ink"
      android:textSize="28sp"
      android:textStyle="bold" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="20dp"
      android:background="@drawable/card_surface"
      android:elevation="1dp"
      android:orientation="vertical"
      android:padding="20dp">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_label"
        android:textColor="@color/slate_500"
        android:textSize="12sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/statusBadgeTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/status_badge_idle"
        android:paddingLeft="12dp"
        android:paddingTop="6dp"
        android:paddingRight="12dp"
        android:paddingBottom="6dp"
        android:text="@string/status_idle"
        android:textColor="@color/slate_700"
        android:textSize="12sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/statusTitleTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="@color/ink"
        android:textSize="22sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/statusDetailTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:lineSpacingExtra="3dp"
        android:textColor="@color/slate_600"
        android:textSize="15sp" />

      <TextView
        android:id="@+id/statusUpdatedAtTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="@color/slate_400"
        android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
      android:id="@+id/pairingCardView"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:background="@drawable/card_surface"
      android:elevation="1dp"
      android:orientation="vertical"
      android:padding="20dp">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pairing_label"
        android:textColor="@color/slate_500"
        android:textSize="12sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/pairingStatusTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="@color/ink"
        android:textSize="16sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/pairingCodeTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/token_surface"
        android:fontFamily="monospace"
        android:padding="14dp"
        android:textColor="@color/slate_700"
        android:textSize="20sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/pairingDetailTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:lineSpacingExtra="3dp"
        android:textColor="@color/slate_600"
        android:textSize="14sp" />

      <LinearLayout
        android:id="@+id/pairedClientContainerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/paired_browser_label"
          android:textColor="@color/slate_500"
          android:textSize="12sp"
          android:textStyle="bold" />

        <ScrollView
          android:layout_width="match_parent"
          android:layout_height="180dp"
          android:layout_marginTop="8dp"
          android:overScrollMode="ifContentScrolls"
          android:scrollbars="vertical">

          <TextView
            android:id="@+id/pairedClientTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/token_surface"
            android:fontFamily="monospace"
            android:lineSpacingExtra="3dp"
            android:padding="14dp"
            android:textColor="@color/slate_700"
            android:textIsSelectable="true"
            android:textSize="13sp" />
        </ScrollView>
      </LinearLayout>
    </LinearLayout>

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:background="@drawable/card_surface"
      android:elevation="1dp"
      android:orientation="vertical"
      android:padding="20dp">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/device_info_label"
        android:textColor="@color/slate_500"
        android:textSize="12sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/deviceNameTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="@color/ink"
        android:textSize="16sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/projectIdTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/slate_600"
        android:textSize="14sp" />

      <TextView
        android:id="@+id/packageNameTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/slate_600"
        android:textSize="14sp" />

      <TextView
        android:id="@+id/senderIdTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/slate_600"
        android:textSize="14sp" />

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/device_installation_id_label"
        android:textColor="@color/slate_500"
        android:textSize="12sp"
        android:textStyle="bold" />

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
          android:id="@+id/deviceInstallationIdTextView"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:background="@drawable/token_surface"
          android:fontFamily="monospace"
          android:padding="14dp"
          android:textColor="@color/slate_700"
          android:textSize="12sp" />

        <Button
          android:id="@+id/copyDeviceInstallationIdButton"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginLeft="10dp"
          android:minHeight="0dp"
          android:minWidth="0dp"
          android:paddingLeft="12dp"
          android:paddingTop="8dp"
          android:paddingRight="12dp"
          android:paddingBottom="8dp"
          android:text="@string/action_copy_device_id"
          android:textAllCaps="false"
          android:textSize="12sp" />
      </LinearLayout>

      <TextView
        android:id="@+id/tokenTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/token_surface"
        android:fontFamily="monospace"
        android:padding="14dp"
        android:textColor="@color/slate_700"
        android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:background="@drawable/card_surface"
      android:elevation="1dp"
      android:orientation="vertical"
      android:padding="20dp">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/message_history_label"
        android:textColor="@color/slate_500"
        android:textSize="12sp"
        android:textStyle="bold" />

      <ScrollView
        android:id="@+id/messageHistoryScrollView"
        android:layout_width="match_parent"
        android:layout_height="360dp"
        android:layout_marginTop="14dp"
        android:scrollbars="vertical"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
          android:id="@+id/messageHistoryContainer"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical" />
      </ScrollView>
    </LinearLayout>

    <LinearLayout
      android:id="@+id/debugCardView"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:background="@drawable/card_surface"
      android:elevation="1dp"
      android:orientation="vertical"
      android:padding="20dp"
      android:visibility="gone">

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:text="@string/debug_label"
          android:textColor="@color/slate_500"
          android:textSize="12sp"
          android:textStyle="bold" />

        <Button
          android:id="@+id/copyDebugLogsButton"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginRight="8dp"
          android:minHeight="0dp"
          android:minWidth="0dp"
          android:paddingLeft="12dp"
          android:paddingTop="8dp"
          android:paddingRight="12dp"
          android:paddingBottom="8dp"
          android:text="@string/debug_action_copy"
          android:textAllCaps="false"
          android:textSize="12sp" />

        <Button
          android:id="@+id/clearDebugLogsButton"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:minHeight="0dp"
          android:minWidth="0dp"
          android:paddingLeft="12dp"
          android:paddingTop="8dp"
          android:paddingRight="12dp"
          android:paddingBottom="8dp"
          android:text="@string/debug_action_clear"
          android:textAllCaps="false"
          android:textSize="12sp" />
      </LinearLayout>

      <TextView
        android:id="@+id/debugLogTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/token_surface"
        android:fontFamily="monospace"
        android:lineSpacingExtra="3dp"
        android:padding="14dp"
        android:textColor="@color/slate_700"
        android:textIsSelectable="true"
        android:textSize="12sp" />
    </LinearLayout>

  </LinearLayout>

</ScrollView>
