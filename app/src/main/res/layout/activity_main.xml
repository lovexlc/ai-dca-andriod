<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/surface_page"
  android:fillViewport="true">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
      android:id="@+id/titleTextView"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/app_name"
      android:textColor="@color/ink"
      android:textSize="28sp"
      android:textStyle="bold" />

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="12dp"
      android:text="@string/main_subtitle"
      android:textColor="@color/slate_600"
      android:textSize="15sp" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="20dp"
      android:background="@drawable/card_surface"
      android:elevation="1dp"
      android:orientation="vertical"
      android:padding="20dp">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_label"
        android:textColor="@color/slate_500"
        android:textSize="12sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/statusBadgeTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/status_badge_idle"
        android:paddingLeft="12dp"
        android:paddingTop="6dp"
        android:paddingRight="12dp"
        android:paddingBottom="6dp"
        android:text="@string/status_idle"
        android:textColor="@color/slate_700"
        android:textSize="12sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/statusTitleTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="@color/ink"
        android:textSize="22sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/statusDetailTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:lineSpacingExtra="3dp"
        android:textColor="@color/slate_600"
        android:textSize="15sp" />

      <TextView
        android:id="@+id/statusUpdatedAtTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="@color/slate_400"
        android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:background="@drawable/card_surface"
      android:elevation="1dp"
      android:orientation="vertical"
      android:padding="20dp">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="前端配对"
        android:textColor="@color/slate_500"
        android:textSize="12sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/pairingStatusTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="@color/ink"
        android:textSize="16sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/pairingCodeTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/token_surface"
        android:fontFamily="monospace"
        android:padding="14dp"
        android:textColor="@color/slate_700"
        android:textSize="20sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/pairingDetailTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:lineSpacingExtra="3dp"
        android:textColor="@color/slate_600"
        android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:background="@drawable/card_surface"
      android:elevation="1dp"
      android:orientation="vertical"
      android:padding="20dp">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/device_info_label"
        android:textColor="@color/slate_500"
        android:textSize="12sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/deviceNameTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="@color/ink"
        android:textSize="16sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/projectIdTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/slate_600"
        android:textSize="14sp" />

      <TextView
        android:id="@+id/packageNameTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/slate_600"
        android:textSize="14sp" />

      <TextView
        android:id="@+id/senderIdTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/slate_600"
        android:textSize="14sp" />

      <TextView
        android:id="@+id/tokenTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/token_surface"
        android:fontFamily="monospace"
        android:padding="14dp"
        android:textColor="@color/slate_700"
        android:textSize="13sp" />
    </LinearLayout>

    <Button
      android:id="@+id/refreshButton"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="18dp"
      android:backgroundTint="@color/indigo_600"
      android:paddingTop="14dp"
      android:paddingBottom="14dp"
      android:text="@string/action_refresh"
      android:textAllCaps="false"
      android:textColor="@android:color/white"
      android:textSize="16sp"
      android:textStyle="bold" />

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:text="@string/main_note"
      android:textColor="@color/slate_500"
      android:textSize="13sp" />
  </LinearLayout>

</ScrollView>
