<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_marginTop="8dp"
  android:background="@drawable/token_surface"
  android:gravity="center_vertical"
  android:orientation="horizontal"
  android:paddingLeft="14dp"
  android:paddingRight="6dp"
  android:paddingTop="10dp"
  android:paddingBottom="10dp">

  <LinearLayout
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:orientation="vertical">

    <TextView
      android:id="@+id/pairedClientNameTextView"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:singleLine="true"
      android:ellipsize="end"
      android:textColor="@color/text_primary"
      android:textSize="13sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/pairedClientIdTextView"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="2dp"
      android:fontFamily="monospace"
      android:singleLine="true"
      android:ellipsize="middle"
      android:textColor="@color/text_tertiary"
      android:textSize="11sp" />
  </LinearLayout>

  <Button
    android:id="@+id/unpairClientButton"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginLeft="8dp"
    android:background="@drawable/btn_text_primary"
    android:minHeight="0dp"
    android:minWidth="0dp"
    android:paddingLeft="14dp"
    android:paddingTop="8dp"
    android:paddingRight="14dp"
    android:paddingBottom="8dp"
    android:stateListAnimator="@null"
    android:text="@string/unpair_action"
    android:textAllCaps="false"
    android:textColor="@color/brand_600"
    android:textSize="12sp"
    android:textStyle="bold" />
</LinearLayout>
